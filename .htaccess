<IfModule mod_dir.c>
    DirectoryIndex index.html index.php
</IfModule>

<IfModule mod_autoindex.c>
    Options -Indexes
</IfModule>

# Admin page protection — route input-*.html through PHP auth gate
RewriteEngine On
RewriteRule ^(input-[a-z0-9-]+\.html)$ /admin-gate.php?p=$1 [L,QSA,NC]

# Fallback: redirect root to index.html
RewriteRule ^$ /index.html [L]
